# ============================================
# ORM Automation Engine — Configuration
# ============================================
# Multi-Platform Publishing: Dev.to + Hashnode + LinkedIn
# 60 articles × 3 platforms = 180 total publishes over 30 days
#
# Setup instructions: See API_SETUP_GUIDE.md

# ---- DEV.TO API (Required) ----
# Get your token: https://dev.to/settings/extensions → Generate API Key
# Takes 30 seconds to set up!
DEVTO_TOKEN=

# ---- HASHNODE API (Required) ----
# Get your token: https://hashnode.com/settings/developer → Generate Personal Access Token
# Get your publication ID: https://hashnode.com/settings/blogs
# Takes 2-3 minutes to set up!
HASHNODE_TOKEN=
HASHNODE_PUBLICATION_ID=

# ---- MEDIUM API (Optional - many accounts don't have access) ----
# Get your token: Medium.com → Settings → Integration Tokens
# Note: Medium has restricted API access for most users
# If you can't get a token, that's fine - Dev.to + Hashnode provide excellent coverage
MEDIUM_TOKEN=
MEDIUM_USER_ID=

# ---- SCHEDULE ----
# When to start publishing (YYYY-MM-DD)
START_DATE=2026-02-11

# Publishing frequency:
#   "daily" = 2 articles/day for 30 days (recommended)
#   "every_other_day" = 2 articles every 2 days for 60 days
FREQUENCY=daily

# Time to publish each day (24hr format, used in daemon mode)
PUBLISH_TIME=09:00

# ---- LINKEDIN (Semi-Automated) ----
# LinkedIn doesn't have a free publishing API
# The script copies articles to clipboard and opens the browser
# You paste and publish (takes 60 seconds per article)
AUTO_OPEN_LINKEDIN=true

# ---- SUBSTACK (Auto-publish) ----
# Substack moved most accounts to passwordless / magic-link login.
# COOKIE AUTH is now the recommended way (see SUBSTACK_COOKIE_SETUP.md):
# 1. Log into substack.com in your browser
# 2. Open DevTools → Application → Cookies → substack.com
# 3. Copy the value of the 'substack.sid' cookie
# 4. Paste it into SUBSTACK_COOKIE below
SUBSTACK_COOKIE=
SUBSTACK_PUB_URL=paulmriv.substack.com

# Fallback: only used if SUBSTACK_COOKIE is empty (often fails for magic-link accounts)
SUBSTACK_EMAIL=
SUBSTACK_PASSWORD=

# ---- CONTENT GENERATION ----
# Used in YouTube scripts, press releases, and slide decks
PERSONAL_SITE_URL=https://pablomrivera.com
YOUTUBE_CHANNEL_URL=

# ---- PRESS RELEASE SUBMISSION (Auto-submit via Playwright) ----
# Create a free account at prlog.org, then fill in:
PRLOG_EMAIL=
PRLOG_PASSWORD=

# ---- YOUTUBE UPLOAD (Auto-upload via OAuth 2.0) ----
# See YOUTUBE_SETUP.md for one-time setup steps:
# 1. Create YouTube channel
# 2. Create Google Cloud project + OAuth credentials
# 3. Use oauthplayground.google.com to generate refresh token
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REFRESH_TOKEN=
