# Environment variables (contains secrets!)
.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
*.egg-info/
.pytest_cache/

# Logs
logs/*.log
!logs/.gitkeep

# Status file (tracked so workflow persists state between runs)
# logs/publish_status.json

# LinkedIn exports (optional - comment out if you want to track these)
logs/linkedin_*.md

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
*.tmp
*.bak

# Video build intermediates (keep final .mp4s, drop the temp slides/audio)
videos/_temp/

# Generated schema export (regenerate with: python publish.py --export-schema)
person_schema.html

# Windows reserved names
nul
credentials.json
blogger_refresh_token.txt
